# Nivo FX Intelligence Suite - Headless Sentinel Environment Variables
# COPY THIS FILE TO .env AND FILL IN YOUR CREDENTIALS
# DO NOT COMMIT .env TO VERSION CONTROL

# OANDA v20 REST API Credentials
OANDA_ACCESS_TOKEN="your_oanda_practice_token_here"
OANDA_ACCOUNT_ID="your_oanda_account_id_here"
# Use 'practice' for demo accounts, 'live' for real trading
OANDA_ENVIRONMENT="practice" 
OANDA_BASE_URL="https://api-fxpractice.oanda.com" # Change to api-fxtrade.oanda.com for live

# n8n Webhook Integration
# Used for routing trade execution signals or alerts to the n8n automation flow
N8N_WEBHOOK_URL="https://your_n8n_instance.com/webhook/nivo_trade_route"
