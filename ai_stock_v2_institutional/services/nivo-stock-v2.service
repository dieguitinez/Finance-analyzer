[Unit]
Description=Nivo AI Stock V2 Institutional Watcher
After=network.target

[Service]
EnvironmentFile=/home/diego/nivo_fx/ai_stock_v2_institutional/.env
User=diego
WorkingDirectory=/home/diego/nivo_fx/ai_stock_v2_institutional/
Environment="PATH=/home/diego/nivo_fx/.venv/bin"
Environment="PYTHONPATH=/home/diego/nivo_fx/ai_stock_v2_institutional"
ExecStart=/home/diego/nivo_fx/.venv/bin/python stock_watcher.py
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
