[Unit]
Description=Nivo Partners Watchdog (RAM & Log Monitor)
After=network.target

[Service]
EnvironmentFile=/home/diego/nivo_fx/ai_forex_sentinel/.env
User=diego
WorkingDirectory=/home/diego/nivo_fx/ai_forex_sentinel/
Environment="PATH=/home/diego/nivo_fx/.venv/bin"
Environment="PYTHONPATH=/home/diego/nivo_fx/ai_forex_sentinel"
ExecStart=/home/diego/nivo_fx/.venv/bin/python nivo_watchdog.py
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
