[Unit]
Description=Nivo AI Stock Telegram Bot
After=network.target

[Service]
EnvironmentFile=/home/diego/nivo_fx/ai_stock_sentinel/.env
User=diego
WorkingDirectory=/home/diego/nivo_fx/
Environment="PATH=/home/diego/nivo_fx/.venv/bin"
ExecStart=/home/diego/nivo_fx/.venv/bin/python ai_stock_sentinel/stock_tg_bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
